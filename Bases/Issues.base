views:
  - type: table
    name: Issue Nodes
    filters:
      and:
        - nodeTypeId == "node_2unblKFUVJkOdOnT8MstZ"
        - template == "[[Issue]]"
    order:
      - file.name
  - type: table
    name: Issues in this Project
    filters:
      and:
        - nodeTypeId == "node_2unblKFUVJkOdOnT8MstZ"
        - project == this.file.name
        - template == "[[Issue]]"
    order:
      - file.name
  - type: table
    name: View
